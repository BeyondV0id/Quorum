{
    "rewrites": [
        {
            "source": "/api/auth/:path*",
            "destination": "https://echo-server-iji0.onrender.com/api/auth/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "https://echo-server-iji0.onrender.com/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}